# ── APP RUNTIME ───────────────────────────────────────────
# App environment mode
# Get values from: https://nodejs.org/api/process.html#processenv
# Required: optional
# Example: development
NODE_ENV=development

# API server port
# Get a free local port from your machine or hosting provider docs
# Required: optional
# Example: 3001
PORT=3001

# Log verbosity for Pino
# Get valid levels from: https://getpino.io/#/docs/api?id=options
# Required: optional
# Example: debug
LOG_LEVEL=debug

# Express session signing secret
# Generate one at: https://www.lastpass.com/features/password-generator
# Required: yes
# Example: pulse_dev_session_secret_please_change_me
SESSION_SECRET=pulse_dev_session_secret_please_change_me

# JWT signing secret for auth cookies and Gmail OAuth state
# Generate one at: https://www.lastpass.com/features/password-generator
# Required: yes
# Example: pulse_dev_jwt_secret_please_change_me
JWT_SECRET=pulse_dev_jwt_secret_please_change_me

# Active LLM key from server/config/models.js
# Choose from your enabled models in code
# Required: optional
# Example: qwen_3_5
ACTIVE_MODEL=qwen_3_5

# ── DATABASE ──────────────────────────────────────────────
# Qdrant Cloud vector database URL
# Get a free cluster at: https://cloud.qdrant.io
# Required: yes
# Example: https://example-cluster.us-east.aws.cloud.qdrant.io:6333
QDRANT_URL=https://your-cluster.qdrant.io:6333

# Qdrant Cloud API key
# Get it from: https://cloud.qdrant.io
# Required: yes
# Example: qdrant_api_key_example_123456
QDRANT_API_KEY=qdrant_api_key_example_123456

# PostgreSQL connection string for sessions, loops, reminders, and email actions
# Get a free Postgres database at: https://neon.tech
# Required: yes
# Example: postgresql://pulse_user:strong_password@ep-cool-darkness-123456.ap-south-1.aws.neon.tech/pulse?sslmode=require
DATABASE_URL=postgresql://pulse_user:strong_password@db.example.neon.tech/pulse?sslmode=require

# MongoDB connection string for user and agent profile documents
# Get a free cluster at: https://www.mongodb.com/cloud/atlas
# Required: yes
# Example: mongodb+srv://pulse-user:strong_password@cluster0.example.mongodb.net/pulse?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://pulse-user:strong_password@cluster0.example.mongodb.net/pulse?retryWrites=true&w=majority

# ── LLM + RETRIEVAL ───────────────────────────────────────
# NVIDIA API key for embeddings, reranking, and the default chat model
# Get it from: https://build.nvidia.com
# Required: yes
# Example: nvapi-example-key-1234567890
NVIDIA_API_KEY=nvapi-example-key-1234567890

# Enable NVIDIA reranker for context refinement
# Get details at: https://build.nvidia.com/nvidia/nv-rerankqa-mistral-4b-v3
# Required: optional
# Example: true
RERANKER_ENABLED=true

# ── SEARCH + TRACKING ─────────────────────────────────────
# Serper API key for competitor search
# Get it from: https://serper.dev
# Required: optional
# Example: serper_example_key_123456
SERPER_API_KEY=serper_example_key_123456

# User ID to run the daily competitor tracker for
# Get it from your database or auth session after signup
# Required: optional
# Example: 67f0c22ab0f6d5bde3f8c123
TRACKER_USER_ID=67f0c22ab0f6d5bde3f8c123

# ── MCP INTEGRATIONS ──────────────────────────────────────
# Enable optional MCP enrichments for Google Calendar and Gmail
# Get usage details at: https://modelcontextprotocol.io
# Required: optional
# Example: true
MCP_ENABLED=true

# Google access token for MCP-backed Google Calendar access
# Create one from your Google OAuth client at: https://console.cloud.google.com
# Required: optional
# Example: ya29.exampleGoogleCalendarToken123456
GOOGLE_ACCESS_TOKEN=ya29.exampleGoogleCalendarToken123456

# Gmail access token for MCP-backed Gmail send and search tools
# Create one from your Google OAuth client at: https://console.cloud.google.com
# Required: optional
# Example: ya29.exampleGmailToken123456
GMAIL_ACCESS_TOKEN=ya29.exampleGmailToken123456

# â”€â”€ NOTION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Optional. Enables Notion profile fetch, open loop sync, and real-time page search.
# Create an integration at: https://www.notion.so/my-integrations
# Then share your pages with the integration inside Notion.
# Required: optional
# Example: secret_exampleNotionToken123456
NOTION_API_KEY=secret_exampleNotionToken123456

# Notion API version used by the official SDK
# Version list: https://developers.notion.com/reference/versioning
# Required: optional
# Example: 2022-06-28
NOTION_VERSION=2022-06-28

# Toggle Notion integration on or off
# Set to true after adding NOTION_API_KEY
# Required: optional
# Example: true
NOTION_ENABLED=true

# Optional default parent page ID for auto-created loop pages
# Get it from your Notion page URL: notion.so/Page-Title-{PAGE_ID}
# Required: optional
# Example: 3262d383c9308089b8bdc87e7f4cfaa
NOTION_DEFAULT_PARENT_PAGE_ID=

# ── GMAIL OAUTH FALLBACK ──────────────────────────────────
# Gmail OAuth client ID for per-user Gmail connections
# Create one at: https://console.cloud.google.com/apis/credentials
# Required: optional
# Example: 123456789012-example.apps.googleusercontent.com
GMAIL_CLIENT_ID=123456789012-example.apps.googleusercontent.com

# Gmail OAuth client secret
# Get it from: https://console.cloud.google.com/apis/credentials
# Required: optional
# Example: GOCSPX-exampleClientSecret123456
GMAIL_CLIENT_SECRET=GOCSPX-exampleClientSecret123456

# Gmail OAuth redirect URI registered in Google Cloud
# Register it at: https://console.cloud.google.com/apis/credentials
# Required: optional
# Example: http://localhost:3001/api/agent-setup/gmail/callback
GMAIL_REDIRECT_URI=http://localhost:3001/api/agent-setup/gmail/callback

# Server-level Gmail refresh token for open-source fallback sending
# Generate it through your OAuth flow in Agent Setup
# Required: optional
# Example: 1//0exampleRefreshToken1234567890
GMAIL_REFRESH_TOKEN=1//0exampleRefreshToken1234567890

# Default sender email for server-level Gmail fallback
# Use the Gmail address tied to your refresh token
# Required: optional
# Example: pulse.bot@example.com
GMAIL_SENDER_EMAIL=pulse.bot@example.com
